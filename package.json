{
  "name": "dt-detailing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
"scripts": {
    "dev": "vite",
    "build": "vite build && npx react-snap", 
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "headless": true,
    "crawl": true,
    "waitFor": 3000,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-gpu"
    ],
    "routes": [
      "/",
      "/maintenance-clean",
      "/deep-clean",
      "/paint-enhancement",
      "/ceramic-coating",
      "/sheffield",
      "/doncaster"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "aos": "^2.3.4",
    "glob": "^13.0.6",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "mkdirp": "^3.0.1",
    "puppeteer": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "react-router-hash-link": "^2.4.3",
    "react-snap": "^1.23.0",
    "rimraf": "^6.1.3",
    "swiper": "^12.1.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^6.0.0",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
